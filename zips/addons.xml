<?xml version="1.0" encoding="UTF-8"?>
<addons>
<addon id="repository.kbxy88" name="Pacific" version="1.1" provider-name="Kbxy88">
    <extension point="xbmc.addon.repository" name="Pacific Repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/Kbxy88/Pacific/master/zips/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/Kbxy88/Pacific/master/zips/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/Kbxy88/Pacific/master/zips/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>Pacific</summary>
        <description>Spreading the basic repo around the group</description>
        <disclaimer></disclaimer>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>

<addon id="plugin.program.voltage" name="[B][COLOR slateblue]Voltage[/COLOR][/B] Wizard" version="1.0" provider-name="Kbxy88">
  <requires>
    <import addon="xbmc.python" version="2.1.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>executable</provides>
  </extension>
  <extension point="xbmc.service" library="startup.py" start="startup" />
  <extension point="xbmc.addon.metadata">
    <summary lang="en">[B][COLOR slateblue]Voltage/COLOR][/B] Wizard</summary>
    <description lang="en">[B][COLOR slateblue]Voltage[/COLOR][/B] Wizard offers many maintenance features, selective add-on data saving, and automated build installs.</description>
    <platform>all</platform>
  </extension>
</addon>

